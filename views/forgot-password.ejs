<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/app.css">
    <link rel="stylesheet" href="/css/login.css">
    <title>Forgot Password | Quill</title>
</head>
<body>
    <main class="login-section">
        <div class="login-card">
            <h2 class="login-heading">Reset Password</h2>
            
            <% if (error) { %><div style="color: red; margin-bottom: 1rem;"><%= error %></div><% } %>
            <% if (success) { %><div style="color: green; margin-bottom: 1rem;"><%= success %></div><% } %>

            <form action="/forgot-password" method="POST">
                <div class="form-group">
                    <label class="form-label">Enter your account email</label>
                    <input class="form-input" type="email" name="email" required>
                </div>
                <button type="submit" class="btn btn-primary btn-wide">Send Reset Link</button>
            </form>
        </div>
    </main>
</body>
</html>